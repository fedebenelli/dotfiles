# i3blocks config file
#
# Please see man i3blocks for a complete reference!
# The man page is also hosted at http://vivien.github.io/i3blocks
#
# List of valid properties:
#
# align
# color
# command
# full_text
# instance
# interval
# label
# min_width
# name
# separator
# separator_block_width
# short_text
# signal
# urgent

# Global properties
#
# The top properties below are applied to every block, but can be overridden.
# Each block command defaults to the script name to avoid boilerplate.
# Change $SCRIPT_DIR to the location of your scripts!
command=$HOME/.config/i3blocks/$BLOCK_NAME/$BLOCK_NAME
separator_block_width=15
markup=none


# Weather
# script from https://github.com/mwallace582/i3blocks-weather
[i3blocks-weather.py]
command=$HOME/.config/i3blocks/i3blocks-weather.py/i3blocks-weather.py -c -k 857c24e12e858c572cc5a98b4bfe6620
markup=pango
interval=100


# Volume indicator

[volume]
LABEL=VOL
interval=1
signal=10
#STEP=5%
#MIXER=[determined automatically]
#SCONTROL=[determined automatically]

# Disk usage
#
# The directory defaults to $HOME if the instance is not specified.
# The script may be called with a optional argument to set the alert
# (defaults to 10 for 10%).
[disk]
label=fs/ 
DIR=/
interval=30
separator=false

[disk]
label=/home/ 
DIR=/home/
interval=15
separator=true


# Memory usage
#
# The type defaults to "mem" if the instance is not specified.
[memory]
label=RAM:
separator=true
interval=30

# Network interface monitoring
#
# If the instance is not specified, use the interface used for default route.
# The address can be forced to IPv4 or IPv6 with -4 or -6 switches.

[iface]
#IFACE=wlan0
color=#00FF00
interval=10
separator=false

[wifi]
INTERFACE=wlan0
label=wifi:
interval=10
separator=true

#[bandwidth]
#INTERFACE=wlan0
#interval=5
#separator=true

# CPU usage
#
# The script may be called with -w and -c switches to specify thresholds,
# see the script for details.
#[cpu_usage]
#label=CPU:
#interval=10
#separator=false
#min_width=CPU 100.00%

[temperature]
label=T=
interval=10
T_WARN=50
T_CRIT=75
SENSOR_CHIP=""


[load_average]
label=LOAD 
interval=10

# Calendar

[calendar]
interval=1
LABEL= 
DATEFMT=+%a %d/%m/%Y %H:%M:%S
HEIGHT=-0
WIDTH=220


# Battery indicator

# The battery instance defaults to 0.
[battery]
label=⚡
interval=30


# Generic media player support
#
# This displays "ARTIST - SONG" if a music is playing.
# Supported players are: spotify, vlc, audacious, xmms2, mplayer, and others.
#[mediaplayer]
#instance=spotify
#interval=5
#signal=10



