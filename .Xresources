! X colors.
! Generated by 'wal'
URxvt.buffered: true
*.font: xft:BitstreamVeraSansMono NF:size=9:antialias=false
URxvt*scrollBar: false
URxvt*secondaryScroll: true
*foreground:        #e8c37f
*background:        #261200
*.foreground:       #e8c37f
*.background:       #261200
emacs*foreground:   #e8c37f
emacs*background:   #261200
URxvt*foreground:   #e8c37f
XTerm*foreground:   #e8c37f
UXTerm*foreground:  #e8c37f
!URxvt*background:   [70]#261200
XTerm*background:   #261200
UXTerm*background:  #261200
URxvt*cursorColor:  #e8c37f
XTerm*cursorColor:  #e8c37f
UXTerm*cursorColor: #e8c37f
URxvt*borderColor:  [70]#261200

! Colors 0-15.
*.color0: #261200
*color0:  #261200
*.color1: #A66C07
*color1:  #A66C07
*.color2: #A47E21
*color2:  #A47E21
*.color3: #C17F0D
*color3:  #C17F0D
*.color4: #AE891E
*color4:  #AE891E
*.color5: #B28915
*color5:  #B28915
*.color6: #DE9611
*color6:  #DE9611
*.color7: #e8c37f
*color7:  #e8c37f
*.color8: #a28858
*color8:  #a28858
*.color9: #A66C07
*color9:  #A66C07
*.color10: #A47E21
*color10:  #A47E21
*.color11: #C17F0D
*color11:  #C17F0D
*.color12: #AE891E
*color12:  #AE891E
*.color13: #B28915
*color13:  #B28915
*.color14: #DE9611
*color14:  #DE9611
*.color15: #e8c37f
*color15:  #e8c37f

! Black color that will not be affected by bold highlighting.
*.color66: #261200
*color66:  #261200

! Xclock colors.
XClock*foreground: #e8c37f
XClock*background: #261200
XClock*majorColor:  rgba:e8/c3/7f/ff
XClock*minorColor:  rgba:e8/c3/7f/ff
XClock*hourColor:   rgba:e8/c3/7f/ff
XClock*minuteColor: rgba:e8/c3/7f/ff
XClock*secondColor: rgba:e8/c3/7f/ff

! Set depth to make transparency work.
URxvt*transparent: true
URxvt*shading: 32
